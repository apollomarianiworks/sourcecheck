rules_version = '2';

// Proofbase / ProofMedia Firestore rules - PASS 24 security hardening.
//
// Client code may validate for UX, but these rules are the enforcement layer:
// ownership, allowed fields, protected fields, public/private visibility, and
// moderation fields are checked here.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true
          || request.auth.token.role == 'admin'
          || request.auth.token.role == 'moderator');
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function restrictions(uid) {
      return userExists(uid) && userData(uid).restrictions is list
        ? userData(uid).restrictions
        : [];
    }

    function notBanned(uid) {
      return !('banned' in restrictions(uid)) && (!userExists(uid) || userData(uid).status == 'active');
    }

    function canWrite(uid, action) {
      return isMe(uid) && notBanned(uid) && !(('no-' + action) in restrictions(uid));
    }

    function isString(v) {
      return v is string;
    }

    function isNullableString(v) {
      return v == null || v is string;
    }

    function validUrl(v) {
      return isString(v)
        && v.size() <= 2048
        && v.matches('^https?://[^\\s<>"`]+$')
        && !v.matches('(?i)^(javascript|data|file|chrome|extension):.*')
        && !v.matches('(?i)^https?://(localhost|127\\.|0\\.|10\\.|169\\.254\\.|172\\.(1[6-9]|2[0-9]|3[0-1])\\.|192\\.168\\.|\\[::1\\]).*');
    }

    function validUrlList(v, maxCount) {
      return v is list && v.size() <= maxCount;
    }

    function validTags(v) {
      return v is list && v.size() <= 10;
    }

    function validUsername(v) {
      return isString(v) && v.size() >= 3 && v.size() <= 24 && v.matches('^[A-Za-z0-9][A-Za-z0-9_-]{1,22}[A-Za-z0-9]$');
    }

    function validDisplayName(v) {
      return isString(v) && v.size() >= 1 && v.size() <= 50 && !v.matches('.*<[^>]+>.*');
    }

    function validBio(v) {
      return v == null || (isString(v) && v.size() <= 300 && !v.matches('.*<[^>]+>.*'));
    }

    function validPublicStatus(data) {
      return data.status in ['active', 'flagged'] && data.moderationStatus in ['clear', 'needs-review'];
    }

    function publicContent(data) {
      return data.visibility == 'public'
        && data.status == 'active'
        && data.moderationStatus in ['clear', null];
    }

    function noProtectedUserChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role',
        'restrictions',
        'reputationScore',
        'followerCount',
        'followingCount',
        'postCount',
        'likeCount',
        'status',
        'moderationStatus'
      ]);
    }

    function noProtectedContentChange() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'authorId',
        'authorUsername',
        'authorDisplayName',
        'authorPhotoURL',
        'status',
        'moderationStatus',
        'score',
        'likeCount',
        'saveCount',
        'commentCount',
        'reportCount',
        'createdAt'
      ]);
    }

    match /users/{uid} {
      allow read: if isMe(uid) || (resource.data.status == 'active' && resource.data.moderationStatus in ['clear', null]);

      allow create: if isMe(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'displayName',
          'photoURL',
          'bio',
          'email',
          'emailVerified',
          'createdAt',
          'updatedAt',
          'reputationScore',
          'role',
          'restrictions',
          'followerCount',
          'followingCount',
          'postCount',
          'likeCount',
          'status',
          'moderationStatus'
        ])
        && request.resource.data.uid == uid
        && validUsername(request.resource.data.username)
        && validDisplayName(request.resource.data.displayName)
        && validBio(request.resource.data.bio)
        && isNullableString(request.resource.data.photoURL)
        && (request.resource.data.photoURL == null || validUrl(request.resource.data.photoURL))
        && request.resource.data.email == null
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && request.resource.data.role == 'user'
        && request.resource.data.restrictions == []
        && request.resource.data.reputationScore == 0
        && request.resource.data.followerCount == 0
        && request.resource.data.followingCount == 0
        && request.resource.data.postCount == 0
        && request.resource.data.likeCount == 0
        && request.resource.data.status == 'active'
        && request.resource.data.moderationStatus == 'clear';

      allow update: if canWrite(uid, 'profile-edit')
        && request.resource.data.uid == uid
        && noProtectedUserChange()
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'displayName',
          'photoURL',
          'bio',
          'email',
          'emailVerified',
          'createdAt',
          'updatedAt',
          'reputationScore',
          'role',
          'restrictions',
          'followerCount',
          'followingCount',
          'postCount',
          'likeCount',
          'status',
          'moderationStatus'
        ])
        && validUsername(request.resource.data.username)
        && validDisplayName(request.resource.data.displayName)
        && validBio(request.resource.data.bio)
        && request.resource.data.email == resource.data.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && (request.resource.data.photoURL == null || validUrl(request.resource.data.photoURL));

      allow delete: if false;
    }

    match /claims/{claimId} {
      allow read: if publicContent(resource.data) || (signedIn() && resource.data.authorId == request.auth.uid) || isAdmin();

      allow create: if canWrite(request.auth.uid, 'post')
        && request.resource.data.keys().hasOnly([
          'authorId',
          'authorUsername',
          'authorDisplayName',
          'authorPhotoURL',
          'title',
          'body',
          'category',
          'tags',
          'evidenceUrls',
          'sourceMeshSummary',
          'visibility',
          'createdAt',
          'updatedAt',
          'score',
          'commentCount',
          'evidenceCount',
          'status',
          'moderationStatus'
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.auth.token.email_verified == true
        && isString(request.resource.data.title)
        && request.resource.data.title.size() >= 8
        && request.resource.data.title.size() <= 180
        && !request.resource.data.title.matches('.*<[^>]+>.*')
        && isString(request.resource.data.body)
        && request.resource.data.body.size() <= 5000
        && !request.resource.data.body.matches('.*<[^>]+>.*')
        && request.resource.data.category in ['politics-news','health-medical','science-research','legal-court','finance-business','technology','celebrity-viral','general']
        && request.resource.data.visibility in ['public','private','draft']
        && validTags(request.resource.data.tags)
        && validUrlList(request.resource.data.evidenceUrls, 5)
        && request.resource.data.sourceMeshSummary == null
        && request.resource.data.score == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.evidenceCount == request.resource.data.evidenceUrls.size()
        && validPublicStatus(request.resource.data);

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && notBanned(request.auth.uid)
        && noProtectedContentChange()
        && request.resource.data.keys().hasOnly([
          'authorId',
          'authorUsername',
          'authorDisplayName',
          'authorPhotoURL',
          'title',
          'body',
          'category',
          'tags',
          'evidenceUrls',
          'sourceMeshSummary',
          'visibility',
          'createdAt',
          'updatedAt',
          'score',
          'commentCount',
          'evidenceCount',
          'status',
          'moderationStatus'
        ])
        && request.resource.data.title.size() >= 8
        && request.resource.data.title.size() <= 180
        && request.resource.data.body.size() <= 5000
        && request.resource.data.visibility in ['public','private','draft']
        && validTags(request.resource.data.tags)
        && validUrlList(request.resource.data.evidenceUrls, 5)
        && request.resource.data.evidenceCount == request.resource.data.evidenceUrls.size();

      allow delete: if signedIn() && resource.data.authorId == request.auth.uid && notBanned(request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if resource.data.status == 'active'
        || (signedIn() && resource.data.authorId == request.auth.uid)
        || isAdmin();

      allow create: if canWrite(request.auth.uid, 'comment')
        && request.auth.token.email_verified == true
        && request.resource.data.keys().hasOnly([
          'claimId',
          'authorId',
          'authorUsername',
          'authorDisplayName',
          'authorPhotoURL',
          'body',
          'type',
          'evidenceUrls',
          'createdAt',
          'updatedAt',
          'score',
          'status'
        ])
        && request.resource.data.authorId == request.auth.uid
        && isString(request.resource.data.claimId)
        && exists(/databases/$(database)/documents/claims/$(request.resource.data.claimId))
        && get(/databases/$(database)/documents/claims/$(request.resource.data.claimId)).data.status == 'active'
        && request.resource.data.type in ['comment','rebuttal','context']
        && isString(request.resource.data.body)
        && request.resource.data.body.size() >= 5
        && request.resource.data.body.size() <= 2000
        && !request.resource.data.body.matches('.*<[^>]+>.*')
        && validUrlList(request.resource.data.evidenceUrls, 5)
        && (request.resource.data.type == 'comment' || request.resource.data.evidenceUrls.size() >= 1)
        && request.resource.data.status == 'active'
        && request.resource.data.score == 0;

      allow update: if signedIn()
        && resource.data.authorId == request.auth.uid
        && notBanned(request.auth.uid)
        && request.resource.data.authorId == resource.data.authorId
        && request.resource.data.claimId == resource.data.claimId
        && request.resource.data.status == resource.data.status
        && request.resource.data.score == resource.data.score
        && request.resource.data.type == resource.data.type
        && request.resource.data.body.size() >= 5
        && request.resource.data.body.size() <= 2000
        && validUrlList(request.resource.data.evidenceUrls, 5);

      allow delete: if signedIn() && resource.data.authorId == request.auth.uid && notBanned(request.auth.uid);
    }

    match /follows/{followId} {
      allow read: if signedIn() && resource.data.followerId == request.auth.uid;
      allow create: if canWrite(request.auth.uid, 'follow')
        && request.resource.data.keys().hasOnly(['followerId', 'targetType', 'targetId', 'createdAt'])
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.targetType in ['user','topic']
        && isString(request.resource.data.targetId)
        && (request.resource.data.targetType != 'user' || userExists(request.resource.data.targetId));
      allow update: if false;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if canWrite(request.auth.uid, 'like')
        && request.resource.data.keys().hasOnly(['userId', 'targetType', 'targetId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.targetType in ['claim','comment']
        && isString(request.resource.data.targetId);
      allow update: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /votes/{voteId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if canWrite(request.auth.uid, 'like')
        && request.resource.data.keys().hasOnly(['userId', 'targetType', 'targetId', 'voteType', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.targetType in ['claim','comment']
        && request.resource.data.voteType in ['up','down']
        && isString(request.resource.data.targetId);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.targetType == resource.data.targetType
        && request.resource.data.targetId == resource.data.targetId
        && request.resource.data.voteType in ['up','down'];
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /saves/{saveId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if canWrite(request.auth.uid, 'save')
        && request.resource.data.keys().hasOnly(['userId', 'targetType', 'targetId', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.targetType in ['claim','comment','collection','routine']
        && isString(request.resource.data.targetId);
      allow update: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if canWrite(request.auth.uid, 'report')
        && request.resource.data.keys().hasOnly(['reporterId', 'targetType', 'targetId', 'reason', 'details', 'createdAt', 'status'])
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.targetType in ['claim','comment','user']
        && isString(request.resource.data.targetId)
        && (request.resource.data.targetType != 'user' || userExists(request.resource.data.targetId))
        && isString(request.resource.data.reason)
        && request.resource.data.reason.size() <= 80
        && isString(request.resource.data.details)
        && request.resource.data.details.size() >= 10
        && request.resource.data.details.size() <= 1000
        && !request.resource.data.details.matches('.*<[^>]+>.*')
        && request.resource.data.status == 'open';
      allow update, delete: if false;
    }

    match /collections/{collectionId} {
      allow read: if resource.data.visibility == 'public'
        || (signedIn() && resource.data.ownerId == request.auth.uid)
        || isAdmin();
      allow create: if signedIn()
        && notBanned(request.auth.uid)
        && request.resource.data.keys().hasOnly(['ownerId', 'title', 'description', 'visibility', 'tags', 'itemIds', 'createdAt', 'updatedAt', 'status', 'moderationStatus'])
        && request.resource.data.ownerId == request.auth.uid
        && isString(request.resource.data.title)
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 120
        && isString(request.resource.data.description)
        && request.resource.data.description.size() <= 1000
        && request.resource.data.visibility in ['public','private']
        && validTags(request.resource.data.tags)
        && request.resource.data.itemIds is list
        && request.resource.data.itemIds.size() <= 200
        && validPublicStatus(request.resource.data);
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && notBanned(request.auth.uid)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.status == resource.data.status
        && request.resource.data.moderationStatus == resource.data.moderationStatus
        && request.resource.data.title.size() >= 1
        && request.resource.data.title.size() <= 120
        && request.resource.data.description.size() <= 1000
        && request.resource.data.visibility in ['public','private'];
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid && notBanned(request.auth.uid);
    }

    match /routines/{routineId} {
      allow read: if signedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if signedIn()
        && notBanned(request.auth.uid)
        && request.resource.data.keys().hasOnly(['ownerId', 'title', 'description', 'prompt', 'visibility', 'createdAt', 'updatedAt', 'lastRunAt', 'status'])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.visibility in ['private-local','share-ready','public-future']
        && isString(request.resource.data.title)
        && request.resource.data.title.size() <= 120
        && isString(request.resource.data.description)
        && request.resource.data.description.size() <= 1000
        && isString(request.resource.data.prompt)
        && request.resource.data.prompt.size() <= 1000
        && request.resource.data.status == 'active';
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && notBanned(request.auth.uid)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.status == resource.data.status
        && request.resource.data.description.size() <= 1000
        && request.resource.data.prompt.size() <= 1000;
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid && notBanned(request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
    }

    match /auditLogs/{auditId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /moderationActions/{actionId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
