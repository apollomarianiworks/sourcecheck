# ---------------------------------------------------------------
# Proofbase environment configuration
#
# Copy this file to ".env.local" and fill in any keys you have.
# Every key is OPTIONAL — the app degrades gracefully without them.
# ---------------------------------------------------------------

# Google Fact Check Tools API — FREE.
#
# Provides direct matches against fact-checks published by
# Politifact, Snopes, FactCheck.org, AFP, Reuters Fact Check, etc.
#
# Without this key:
#   - The app still works.
#   - You only get GDELT news coverage + Wikipedia context.
#   - The verdict will be "RELATED-ONLY" rather than supports/disputes/mixed.
#
# How to get one (no billing required):
#   1. Open https://console.cloud.google.com/
#   2. Create or pick a project.
#   3. Go to "APIs & Services" → "Library".
#   4. Search "Fact Check Tools API" and click ENABLE.
#   5. Go to "APIs & Services" → "Credentials" → "Create credentials" → "API key".
#   6. (Recommended) Restrict the key to "Fact Check Tools API" only.
#   7. Paste the key below.
#
FACTCHECK_API_KEY=

# Optional web/news/source expansion. The app works without these keys.
BRAVE_SEARCH_API_KEY=
NEWSDATA_API_KEY=
MEDIASTACK_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
GITHUB_TOKEN=

# Future AI providers. The current assistant has a rule-based grounded fallback.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
HUGGINGFACE_API_KEY=
LOCAL_MODEL_URL=

# ──────────────────────────────────────────────────────────────────────────
# Firebase Auth + Firestore — required for ProofMedia social features.
#
# Without these, the fact-checking tools still work, but /community, /login,
# /signup, /profile, and saves/votes/reports are disabled with an honest
# "setup needed" UI.
#
# How to set them up:
#   1. Open https://console.firebase.google.com/
#   2. Create (or pick) a project.
#   3. Add a Web app — Firebase shows you these keys.
#   4. Enable Authentication → Sign-in method → Email/Password AND Google.
#   5. Enable Firestore Database → start in production mode.
#   6. Deploy the rules in firestore.rules (firebase deploy --only firestore:rules).
#   7. Paste the keys below and restart `npm run dev`.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
